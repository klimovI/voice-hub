# CF orange-cloud terminates client TLS; Caddy only serves 443 to CF.
{
	auto_https disable_redirects
}

{$APP_HOSTNAME} {
	# Authenticated Origin Pulls — mTLS belt over CF-IP-only firewall.
	tls /etc/caddy/origin.crt /etc/caddy/origin.key {
		client_auth {
			mode require_and_verify
			trusted_ca_cert_file /etc/caddy/cf-origin-ca.pem
		}
	}

	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "microphone=(self), camera=(), geolocation=()"
		Content-Security-Policy "default-src 'self'; connect-src 'self' wss: https:; script-src 'self' 'wasm-unsafe-eval' blob:; worker-src 'self' blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; media-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
		-Server
		-Via
	}

	# Vendor WASM/JS denoiser blobs are content-pinned; cache aggressively.
	@vendor path /vendor/*
	header @vendor Cache-Control "public, max-age=31536000, immutable"

	# Vite-emitted assets carry content hashes in filenames; safe to pin.
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# HTML entry points must always revalidate so version-poll banner can
	# detect new deploys without users hard-refreshing.
	@html path / /index.html /login.html
	header @html Cache-Control "no-cache"

	reverse_proxy app:8080
}
