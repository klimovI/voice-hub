{$APP_HOSTNAME} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "microphone=(self), camera=(), geolocation=()"
		Content-Security-Policy "default-src 'self'; connect-src 'self' wss: https:; script-src 'self' 'wasm-unsafe-eval'; worker-src 'self' blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; media-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
		-Server
	}

	# Vendor WASM/JS denoiser blobs are content-pinned; cache aggressively.
	@vendor path /vendor/*
	header @vendor Cache-Control "public, max-age=31536000, immutable"

	# Vite-emitted assets carry content hashes in filenames; safe to pin.
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# HTML entry points must always revalidate so version-poll banner can
	# detect new deploys without users hard-refreshing.
	@html path / /index.html /login.html
	header @html Cache-Control "no-cache"

	# App runs in host network namespace and binds the docker bridge gateway
	# IP 10.200.200.1 (pinned in docker-compose.prod.yml). Caddy is on that
	# bridge so the gateway is its default route — direct hop, no DNS.
	# UFW must allow 8080/tcp from 10.200.200.0/24.
	reverse_proxy 10.200.200.1:8080
}
