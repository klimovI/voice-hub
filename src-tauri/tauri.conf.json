{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Audio Room",
  "version": "0.1.0",
  "identifier": "com.audio-room.desktop",
  "build": {
    "frontendDist": "../web"
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Audio Room",
        "width": 1440,
        "height": 980,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": [
        "default"
      ]
    }
  }
}
